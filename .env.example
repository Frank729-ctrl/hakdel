# HakDel — copy to .env and fill in values
# This file is safe to commit. The actual .env is gitignored.

# ── Database (PHP frontend) ────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=hakdel
DB_USER=root
DB_PASS=your_db_password_here

# ── Scanner API ────────────────────────────────────────────────────────────────
API_BASE=http://localhost:8000
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here
NVD_API_KEY=your_nvd_api_key_here         # https://nvd.nist.gov/developers/request-an-api-key

# ── Frontend ───────────────────────────────────────────────────────────────────
SITE_URL=http://localhost:8080
APP_ENV=development                        # development | production

# ── Anthropic (AI Scan Interpreter) ───────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here   # https://console.anthropic.com

# ── Security Tool APIs ─────────────────────────────────────────────────────────
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here   # https://www.abuseipdb.com/api
SHODAN_API_KEY=your_shodan_api_key_here          # https://account.shodan.io
GOOGLE_SAFE_BROWSING_KEY=your_gsb_key_here      # https://developers.google.com/safe-browsing (free)
WATCHLIST_CRON_TOKEN=generate_random_32char_hex  # e.g. openssl rand -hex 16

# ── Payments (Paystack) ────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_live_your_paystack_secret_key   # https://dashboard.paystack.com/#/settings/developer
PAYSTACK_PUBLIC_KEY=pk_live_your_paystack_public_key   # used client-side if needed

# ── Google OAuth ───────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8080/auth/google_callback.php

# ── SMTP ───────────────────────────────────────────────────────────────────────
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_USER=your_email@yourdomain.com
MAIL_PASS=your_smtp_password_here
MAIL_FROM=your_email@yourdomain.com
MAIL_FROM_NAME=HakDel
